{
    "version": 2,
    "framework": null,
    "outputDirectory": "public",
    "buildCommand": "php composer.phar install --no-dev --optimize-autoloader --no-interaction",
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.8.0",
            "includeFiles": "{app,bootstrap,config,database,resources/views,routes,vendor}/**"
        }
    },
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "/(css|js|images|fonts)/(.*)",
            "dest": "/public/$1/$2"
        },
        {
            "src": "/favicon.ico",
            "dest": "/public/favicon.ico"
        },
        {
            "src": "/robots.txt",
            "dest": "/public/robots.txt"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ]
}
