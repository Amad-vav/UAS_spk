{
    "version": 2,
    "framework": null,
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.3",
            "includeFiles": "{app,bootstrap,config,database,resources/views,routes,vendor}/**"
        }
    },
    "rewrites": [
        {
            "source": "/build/(.*)",
            "destination": "/public/build/$1"
        },
        {
            "source": "/(css|js|images|fonts)/(.*)",
            "destination": "/public/$1/$2"
        },
        {
            "source": "/favicon.ico",
            "destination": "/public/favicon.ico"
        },
        {
            "source": "/robots.txt",
            "destination": "/public/robots.txt"
        },
        {
            "source": "/(.*)",
            "destination": "/api/index.php"
        }
    ]
}